{
  "_comment": "Copy to config.json and edit. config.json is gitignored. Secrets should be referenced by env-var name (password_env) and supplied via the environment, not inlined here.",

  "poll_interval_seconds": 30,
  "offline_grace_seconds": 300,
  "presence_away_grace_seconds": 900,
  "unknown_device_alert_cooldown_seconds": 3600,
  "event_dedupe_cooldown_seconds": 600,

  "diagnostics": {
    "internet_check_enabled": true,
    "internet_failure_threshold": 3,
    "internet_recovery_threshold": 2,
    "dns_failure_threshold": 2,
    "latency_degraded_ms": 100,
    "latency_failure_samples": 3,
    "jitter_degraded_ms": 50,
    "packet_loss_degraded_percent": 5,
    "packet_loss_failure_samples": 3,
    "wifi_poor_rssi_dbm": -75,
    "wifi_critical_rssi_dbm": -82,
    "wifi_poor_sample_threshold": 3,
    "wifi_recovery_sample_threshold": 2,
    "health_history_limit": 1000
  },

  "sources": [
    {
      "id": "flint2",
      "type": "glinet",
      "display_name": "Flint 2",
      "base_url": "http://192.168.8.1",
      "enabled": true,
      "capabilities": [
        "dhcpLeases",
        "wifiAssociations",
        "interfaceCounters",
        "routerHealth",
        "firewallSummary"
      ],
      "options": {
        "username": "root",
        "password_env": "GLINET_PASSWORD"
      }
    }
  ],

  "persons": [
    {
      "person_id": "person_demo",
      "display_name": "Demo Person",
      "primary_device_ids": ["dev_phone_alex"],
      "supporting_device_ids": ["dev_laptop_alex"]
    }
  ]
}
